VITE_AIRTABLE_API_KEY=
VITE_AIRTABLE_BASE_ID=
VITE_AIRTABLE_PIPELINE_TABLE=Active Pipeline
VITE_AIRTABLE_DOCUMENTS_TABLE=Documents
VITE_AIRTABLE_SUBMISSION_TABLE=Submission_Log
VITE_LENDER_ROOM_PASSWORD=

# ─── Async Job Queue (Upstash QStash) ─────────────────────────────────────
# Required for production async AI processing. Without these, all AI endpoints
# fall back to synchronous processing (suitable for local dev only).
#
# Get credentials at: https://console.upstash.com/qstash
#
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ─── Application URL ───────────────────────────────────────────────────────
# Used by QStash to call back into your app's job worker endpoints.
# On Vercel, VERCEL_URL is set automatically (do not set it yourself).
# For local dev with QStash tunnel, set this to your ngrok/tunnel URL:
# APP_URL=https://your-tunnel.ngrok.io
APP_URL=
