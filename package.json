{
  "name": "aysan-capital-portal",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"lib/core/**/*.ts\"",
    "format:check": "prettier --check \"lib/core/**/*.ts\"",
    "etl:list": "node --env-file=.env --import tsx scripts/etl/list-tables.ts",
    "etl:count": "node --env-file=.env --import tsx scripts/etl/count-rows.ts",
    "db:migrate": "node --env-file=.env --import tsx scripts/db/migrate.ts",
    "etl:migrate": "node --env-file=.env --import tsx scripts/etl/migrate.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sparticuz/chromium": "^149.0.0",
    "@supabase/supabase-js": "^2.110.4",
    "@upstash/qstash": "^2.11.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cookie": "^1.1.1",
    "inngest": "^4.5.0",
    "jose": "^6.2.3",
    "lucide-react": "^0.511.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "playwright-core": "^1.60.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie": "^0.6.0",
    "@types/node": "^22.15.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vercel/edge": "^1.3.1",
    "@vercel/node": "^5.8.16",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "pg": "^8.22.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.4",
    "prettier": "^3.9.5",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.1",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.34.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "esbuild@0.27.0": true,
    "esbuild@0.27.7": true,
    "protobufjs@7.6.2": true,
    "tesseract.js@7.0.0": true
  }
}
