{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/jobs/worker.ts": {
      "maxDuration": 300
    },
    "api/documents/upload.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/jobs/worker",
      "schedule": "* * * * *"
    }
  ]
}
